{
	"name": "@clawguard/webhook",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"db:create": "wrangler d1 create clawguard-licenses",
		"db:migrate": "wrangler d1 execute clawguard-licenses --file=src/schema.sql",
		"db:migrate:local": "wrangler d1 execute clawguard-licenses --local --file=src/schema.sql",
		"build": "echo 'Worker builds handled by wrangler'"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.0.0",
		"wrangler": "^3.0.0"
	}
}
