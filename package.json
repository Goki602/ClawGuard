{
	"name": "claw-guard-monorepo",
	"private": true,
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "npm run build -w packages/core && npm run build --workspaces --if-present",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"clean": "npm run clean --workspaces --if-present"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
